--- !u!114 &1905175132
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1905175126}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 07e49d75ef17ac544b71b91396bfa2ab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  buildingName: "\u798F\u5EFA\u571F\u697C"
  detailSprite1: {fileID: 21300000, guid: e625f85b5b92c434c9bc5974db285240, type: 3}
  detailSprite2: {fileID: 21300000, guid: 84690a2968c822342b871e9c78a87349, type: 3}
  introduction1: "\u798F\u5EFA\u571F\u697C\u662F\u4E00\u79CD\u5927\u578B\u805A\u65CF\u800C\u5C45\u7684\u6C11\u5C45\u5EFA\u7B51\uFF0C\u901A\u5E38\u7531\u4E00\u4E2A\u5BB6\u65CF\u6216\u591A\u4E2A\u5BB6\u65CF\u5171\u540C\u5C45\u4F4F\uFF0C\u56F4\u7ED5\u4E2D\u5FC3\u7A7A\u95F4\u5C55\u5F00\u65E5\u5E38\u751F\u6D3B\u3002\n\n\u5728\u798F\u5EFA\u5C71\u533A\u8D44\u6E90\u6709\u9650\u3001\u4EA4\u901A\u4E0D\u4FBF\u7684\u6761\u4EF6\u4E0B\uFF0C\u4EBA\u4EEC\u5229\u7528\u592F\u571F\u5899\u4F53\u7ED3\u6784\u5C31\u5730\u53D6\u6750\u5EFA\u9020\u623F\u5C4B\u3002\u540C\u65F6\u5728\u793E\u4F1A\u73AF\u5883\u4E0D\u7A33\u5B9A\u7684\u65F6\u671F\uFF0C\u901A\u8FC7\u539A\u5899\u9632\u5FA1\u7ED3\u6784\u63D0\u5347\u5B89\u5168\u6027\uFF0C\u5E76\u501F\u52A9\u6728\u7ED3\u6784\u697C\u5C42\u4F53\u7CFB\u4E0D\u65AD\u5411\u4E0A\u6269\u5C55\u7A7A\u95F4\uFF0C\u4EE5\u6EE1\u8DB3\u4EBA\u53E3\u589E\u957F\u7684\u9700\u6C42\u3002\n\n\u571F\u697C\u5185\u90E8\u7A7A\u95F4\u7531\u591A\u5C42\u7ED3\u6784\u6784\u6210\uFF0C\u5C45\u4F4F\u3001\u50A8\u85CF\u4E0E\u516C\u5171\u6D3B\u52A8\u96C6\u4E2D\u5728\u540C\u4E00\u5EFA\u7B51\u4E2D\uFF0C\u800C\u5916\u56F4\u7684\u5899\u4F53\u5F62\u6210\u4FDD\u62A4\u8FB9\u754C\uFF0C\u4F7F\u5185\u90E8\u751F\u6D3B\u4E0E\u5916\u90E8\u73AF\u5883\u5F62\u6210\u6E05\u6670\u5206\u9694\u3002\n"
  introduction2: "\u5728\u5386\u53F2\u4E0A\uFF0C\u5F53\u5730\u5C45\u6C11\u5728\u906D\u9047\u76D7\u532A\u65F6\uFF0C\u4F1A\u5173\u95ED\u571F\u697C\u552F\u4E00\u7684\u5927\u95E8\uFF0C\u65CF\u4EBA\u96C6\u4E2D\u5728\u5185\u90E8\u5171\u540C\u9632\u5B88\u3002\u539A\u91CD\u7684\u5899\u4F53\u4E0E\u6709\u9650\u7684\u5165\u53E3\u4F7F\u571F\u697C\u5728\u5173\u952E\u65F6\u523B\u80FD\u591F\u62B5\u5FA1\u5916\u90E8\u5A01\u80C1\uFF0C\u6210\u4E3A\u771F\u6B63\u610F\u4E49\u4E0A\u7684\u201C\u5BB6\u65CF\u5821\u5792\u201D\u3002\n\n\u571F\u697C\u5728\u660E\u6E05\u65F6\u671F\u9010\u6E10\u6210\u719F\uFF0C\u5E76\u957F\u671F\u5728\u798F\u5EFA\u5730\u533A\u5EF6\u7EED\u4F7F\u7528\uFF0C\u6210\u4E3A\u5177\u6709\u4EE3\u8868\u6027\u7684\u6C11\u5C45\u5F62\u5F0F\u3002\n\n\u571F\u697C\u901A\u8FC7\u591A\u79CD\u7ED3\u6784\u7684\u7EC4\u5408\uFF0C\u56DE\u5E94\u4E86\u5C45\u4F4F\u3001\u5B89\u5168\u4E0E\u4EBA\u53E3\u53D1\u5C55\u7684\u591A\u91CD\u9700\u6C42\u3002"
  finalIntroduction: "\u2014\u2014\u798F\u5EFA\u6C38\u5B9A\u3001\u5357\u9756\u7B49\u5730\u4ECD\u4FDD\u5B58\u5927\u91CF\u571F\u697C\u7FA4\uFF0C\u5DF2\u88AB\u5217\u5165\u4E16\u754C\u6587\u5316\u9057\u4EA7\u3002\n\n\u2014\u2014\u798F\u5EFA\u571F\u697C\u666F\u533A\uFF08\u6C38\u5B9A\u3001\u5357\u9756\uFF09\u8BBE\u6709\u571F\u697C\u535A\u7269\u9986\u4E0E\u5C55\u793A\u4E2D\u5FC3\uFF0C\u53EF\u7CFB\u7EDF\u4E86\u89E3\u5176\u7ED3\u6784\u4E0E\u5386\u53F2\u3002"
