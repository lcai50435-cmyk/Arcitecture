--- !u!114 &2145721211906258427
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2836817882156196424}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 07e49d75ef17ac544b71b91396bfa2ab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  buildingName: "\u8D75\u6784\u6865"
  detailSprite1: {fileID: 21300000, guid: 5411062022e290543b2afbe206cf1200, type: 3}
  detailSprite2: {fileID: 21300000, guid: 97e9c100fb98a52489206ab09f6371d1, type: 3}
  introduction1: "\u8D75\u5DDE\u6865\u662F\u968B\u4EE3\u5EFA\u9020\u7684\u77F3\u62F1\u6865\uFF0C\u662F\u4E2D\u56FD\u53E4\u4EE3\u6865\u6881\u5DE5\u7A0B\u7684\u91CD\u8981\u4EE3\u8868\u4E4B\u4E00\u3002\n\n\u9762\u5BF9\u6C34\u6D41\u53D8\u5316\u8F83\u5927\u7684\u6CB3\u6D41\u73AF\u5883\uFF0C\u4EBA\u4EEC\u9700\u8981\u4E00\u79CD\u7A33\u5B9A\u53EF\u9760\u7684\u901A\u884C\u65B9\u5F0F\u3002\u56E0\u6B64\u5728\u5EFA\u9020\u65F6\uFF0C\u91C7\u7528\u5355\u5B54\u62F1\u5238\u7ED3\u6784\u8DE8\u8D8A\u6CB3\u9053\uFF0C\u7ED3\u5408\u655E\u80A9\u5C0F\u62F1\u7ED3\u6784\u51CF\u5C11\u91CD\u91CF\u4E0E\u5206\u6D41\u6C34\u6D41\uFF0C\u5E76\u901A\u8FC7\u62F1\u77F3\u62FC\u63A5\u7ED3\u6784\u4FDD\u8BC1\u6574\u4F53\u7A33\u56FA\uFF0C\u4F7F\u6865\u6881\u80FD\u591F\u957F\u671F\u9002\u5E94\u81EA\u7136\u73AF\u5883\u3002\n\n\u6865\u6881\u5728\u4E0D\u540C\u6C34\u4F4D\u6761\u4EF6\u4E0B\u4FDD\u6301\u901A\u884C\u529F\u80FD\uFF0C\u6C34\u6D41\u53EF\u4EE5\u901A\u8FC7\u4E3B\u62F1\u4E0E\u5C0F\u62F1\u7ED3\u6784\u5206\u6563\uFF0C\u4ECE\u800C\u51CF\u5C11\u5BF9\u6574\u4F53\u7ED3\u6784\u7684\u5F71\u54CD\u3002\n"
  introduction2: "\u76F8\u4F20\u5728\u5EFA\u6865\u8FC7\u7A0B\u4E2D\uFF0C\u4EBA\u4EEC\u5BF9\u5982\u6B64\u8DE8\u5EA6\u7684\u77F3\u62F1\u7ED3\u6784\u662F\u5426\u7A33\u56FA\u5FC3\u5B58\u7591\u8651\u3002\u4F46\u6865\u5EFA\u6210\u540E\uFF0C\u4E0D\u4EC5\u987A\u5229\u901A\u884C\uFF0C\u8FD8\u5728\u4E4B\u540E\u7684\u5C81\u6708\u4E2D\u591A\u6B21\u7ECF\u5386\u6D2A\u6C34\u8003\u9A8C\u800C\u4F9D\u7136\u7A33\u56FA\uFF0C\u8FD9\u79CD\u5B9E\u9645\u4F7F\u7528\u4E2D\u7684\u9A8C\u8BC1\uFF0C\u8BA9\u8D75\u5DDE\u6865\u9010\u6E10\u88AB\u89C6\u4E3A\u5DE5\u7A0B\u6280\u672F\u7684\u5178\u8303\u3002\n\n\u8D75\u5DDE\u6865\u5EFA\u6210\u81F3\u4ECA\u5DF2\u67091400\u591A\u5E74\uFF0C\u7ECF\u5386\u591A\u6B21\u6D2A\u6C34\u4ECD\u57FA\u672C\u4FDD\u6301\u539F\u6709\u7ED3\u6784\u3002\n\n\u8D75\u5DDE\u6865\u901A\u8FC7\u7ED3\u6784\u7EC4\u5408\uFF0C\u5E94\u5BF9\u6C34\u6D41\u73AF\u5883\u4E0E\u957F\u671F\u4F7F\u7528\u9700\u6C42\uFF0C\u662F\u53E4\u4EE3\u5DE5\u7A0B\u5B9E\u8DF5\u7684\u91CD\u8981\u4F53\u73B0\u3002\n\n"
  finalIntroduction: "\u2014\u2014\u4F4D\u4E8E\u6CB3\u5317\u7701\u8D75\u53BF\u6D28\u6CB3\u4E4B\u4E0A\uFF0C\u662F\u73B0\u5B58\u6700\u65E9\u7684\u5927\u578B\u77F3\u62F1\u6865\u4E4B\u4E00\u3002\n\n\u2014\u2014\u8D75\u5DDE\u6865\u666F\u533A\u8BBE\u6709\u9648\u5217\u9986\uFF0C\u5C55\u793A\u6865\u6881\u7ED3\u6784\u4E0E\u5EFA\u9020\u5386\u53F2\u3002"
